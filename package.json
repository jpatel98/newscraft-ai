{
	"name": "hermes-ui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:harness": "pnpm --filter @newscraft/newsroom-harness dev",
		"build": "vite build",
		"build:harness": "pnpm --filter @newscraft/shared build && pnpm --filter @newscraft/newsroom-harness build",
		"health:agent": "node scripts/check-health.mjs --url http://127.0.0.1:3001/api/health --expect ui",
		"health:harness": "node scripts/check-health.mjs --url http://127.0.0.1:8650/health --expect harness",
		"agent:ask": "pnpm --filter @newscraft/newsroom-harness agent:ask --",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run && pnpm --filter @newscraft/shared test && pnpm --filter @newscraft/newsroom-harness test",
		"test:harness": "pnpm --filter @newscraft/shared test && pnpm --filter @newscraft/newsroom-harness test",
		"test:e2e": "playwright test",
		"producer:acceptance": "node scripts/producer-acceptance.mjs",
		"smoke:producer:fixture": "PRODUCER_ACCEPTANCE_SOURCE_MODE=fixture PRODUCER_ACCEPTANCE_REQUIRE_OPENAI=0 node scripts/producer-acceptance.mjs",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"hash-password": "node scripts/hash-password.mjs"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.2",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.0.0"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"better-sqlite3": "^12.9.0",
		"dompurify": "^3.4.2",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^1.0.1",
		"marked": "^18.0.2",
		"postgres": "^3.4.9",
		"shiki": "^4.0.2"
	},
	"pnpm": {
		"overrides": {
			"cookie": "0.7.2",
			"esbuild": "0.27.7"
		},
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"@node-rs/argon2",
			"esbuild"
		]
	}
}
