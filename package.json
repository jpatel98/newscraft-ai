{
	"name": "hermes-ui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build/index.js",
		"deploy:agent": "sudo bash /home/jigar/deploy-hermes-ui.sh --deploy",
		"reload:agent": "bash ./scripts/reload-agent.sh",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"hash-password": "node scripts/hash-password.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.0.0"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"better-sqlite3": "^12.9.0",
		"dompurify": "^3.4.1",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^1.0.1",
		"marked": "^18.0.2",
		"shiki": "^4.0.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"@node-rs/argon2",
			"esbuild"
		]
	}
}
