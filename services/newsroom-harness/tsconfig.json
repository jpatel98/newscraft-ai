{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@newscraft/shared": ["../../packages/shared/src/index.ts"]
		},
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*.ts"],
	"references": [{ "path": "../../packages/shared" }]
}
