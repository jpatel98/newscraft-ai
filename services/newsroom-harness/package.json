{
	"name": "@newscraft/newsroom-harness",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"bin": {
		"newsroom-harness": "./dist/index.js"
	},
	"scripts": {
		"dev": "pnpm --filter @newscraft/shared build && tsx watch src/index.ts",
		"agent:ask": "tsx src/agent-ask.ts",
		"build": "tsc -b tsconfig.json && rm -rf dist/prompts && cp -R prompts dist/prompts",
		"start": "node dist/index.js",
		"test": "pnpm --filter @newscraft/shared build && vitest run --config vitest.config.ts"
	},
	"dependencies": {
		"@newscraft/shared": "workspace:*",
		"better-sqlite3": "^12.9.0",
		"dotenv": "^17.4.2",
		"postgres": "^3.4.9",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.6.2",
		"tsx": "^4.20.6",
		"typescript": "^6.0.2",
		"vitest": "^4.0.0"
	}
}
