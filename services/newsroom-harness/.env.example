NEWSROOM_HARNESS_HOST=127.0.0.1
NEWSROOM_HARNESS_PORT=8650
NEWSROOM_HARNESS_DB_PATH=.data/newsroom-harness.db

# Optional. When set, every endpoint except GET /health requires:
# Authorization: Bearer <NEWSROOM_HARNESS_API_KEY>
NEWSROOM_HARNESS_API_KEY=

# Optional for deterministic local/dev mode. When set, chat and mission runs use
# the OpenAI Agents SDK runtime.
OPENAI_API_KEY=

# Optional. When set, completed mission reports are posted to the SvelteKit UI.
NEWSROOM_UI_INGEST_URL=http://127.0.0.1:3001/api/hermes/channel-posts
NEWSROOM_UI_INGEST_KEY=
